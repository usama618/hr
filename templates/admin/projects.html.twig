{% extends 'base.html.twig' %}

{% block title %}Projects | Waldbyte HR{% endblock %}

{% block body %}
    <div class="page-title">
        <div>
            <h1>Projects</h1>
            <p class="muted">Assign employees here to control project access.</p>
        </div>
        <a class="button" href="{{ path('admin_project_new') }}">Add Project</a>
    </div>

    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Client</th>
                    <th>Status</th>
                    <th>Employees</th>
                    <th>Deadline</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for project in projects %}
                    <tr>
                        <td>
                            <strong>{{ project.name }}</strong>
                            {% if project.description %}
                                <div class="muted">{{ project.description }}</div>
                            {% endif %}
                        </td>
                        <td>{{ project.clientName ?: '-' }}</td>
                        <td><span class="badge">{{ project.status|status_label }}</span></td>
                        <td>{{ project.employees|length }}</td>
                        <td>{{ project.deadline ? project.deadline|date('Y-m-d') : '-' }}</td>
                        <td>
                            <div class="table-actions">
                                <a class="button button-secondary" href="{{ path('admin_project_edit', {id: project.id}) }}">Edit</a>
                                <form
                                    method="post"
                                    action="{{ path('admin_project_delete', {id: project.id}) }}"
                                    onsubmit="return confirm('Remove project {{ project.name|e('js') }}? This will also remove its tasks and timer history.');"
                                >
                                    <input type="hidden" name="_token" value="{{ csrf_token('project_delete_' ~ project.id) }}">
                                    <button type="submit" class="danger">Remove</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="empty">No projects yet.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
{% endblock %}
