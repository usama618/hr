{% extends 'base.html.twig' %}

{% block title %}Tasks | Waldbyte HR{% endblock %}

{% block body %}
    <div class="page-title task-workspace-title">
        <div><span class="panel-label">Work Management</span><h1>Tasks</h1><p class="muted">Choose a project and organize its work into tasks and subtasks.</p></div>
        {% if selected_project %}<a class="button" href="{{ path('admin_task_new', {project: selected_project.id}) }}">Add Task</a>{% endif %}
    </div>

    <div class="task-workspace">
        <aside class="card task-project-nav" aria-label="Projects">
            <div class="task-project-nav-head"><div><span class="panel-label">Workspace</span><h2>Projects</h2></div><span class="badge">{{ projects|length }}</span></div>
            <nav>
                {% for project in projects %}
                    <a class="task-project-link{% if selected_project and project.id == selected_project.id %} active{% endif %}" href="{{ path('admin_tasks', {project: project.id}) }}">
                        <span><strong>{{ project.name }}</strong><small>{{ project.status|status_label }}</small></span>
                        <span class="task-project-count">{{ project.tasks|length }}</span>
                    </a>
                {% else %}
                    <p class="muted">No projects yet.</p><a class="button" href="{{ path('admin_project_new') }}">Add Project</a>
                {% endfor %}
            </nav>
        </aside>

        <section class="card task-tree-panel">
            {% if selected_project %}
                <div class="task-tree-head"><div><span class="panel-label">Selected Project</span><h2>{{ selected_project.name }}</h2></div><span class="badge">{{ task_rows|length }} tasks</span></div>
                <div class="task-tree-scroll">
                    <table class="task-tree" role="treegrid" aria-label="Tasks for {{ selected_project.name }}">
                        <thead><tr><th>Task</th><th>Assignees</th><th>Status</th><th>Priority</th><th>Tags</th><th>Schedule</th><th>Time</th><th></th></tr></thead>
                        <tbody>{% include 'admin/_task_tree_rows.html.twig' with {task_rows: task_rows, selected_project: selected_project} only %}</tbody>
                    </table>
                </div>
                {% if task_rows is empty %}<div class="empty task-empty"><h3>No tasks in this project</h3><p class="muted">Create the first task to begin planning the work.</p><a class="button" href="{{ path('admin_task_new', {project: selected_project.id}) }}">Add Task</a></div>{% endif %}
            {% else %}
                <div class="empty"><h2>Create a project first</h2><p class="muted">Tasks are always organized within a project.</p></div>
            {% endif %}
        </section>
    </div>

    {% if selected_task %}
        {% include 'admin/_task_detail_panel.html.twig' with {selected_task: selected_task, selected_project: selected_project} only %}
    {% endif %}
{% endblock %}
