<section class="task-detail-dialog" data-task-dialog aria-labelledby="task-dialog-title" role="dialog" aria-modal="true">
    {% set is_active_timer = active_task_entry and active_task_entry.task and active_task_entry.task.id == selected_task.id %}
    <a class="task-dialog-backdrop" href="{{ path('admin_tasks', {project: selected_project.id}) }}" aria-label="Close task"></a>
    <div class="task-dialog-surface">
        <header class="task-dialog-head">
            <div><span class="panel-label">Task #{{ selected_task.id }}{% if selected_task.parent %} · Subtask{% endif %}</span><h2 id="task-dialog-title">{{ selected_task.title }}</h2><p class="muted">By {{ selected_task.createdBy ? selected_task.createdBy.fullName : 'Admin' }} · {{ selected_project.name }}</p></div>
            <div class="actions">
                {% if selected_task.status != 'completed' or is_active_timer %}
                    <form method="post" action="{{ path(is_active_timer ? 'admin_task_detail_timer_stop' : 'admin_task_detail_timer_start', {id: selected_task.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('task_timer_' ~ selected_task.id) }}">
                        <button type="submit" class="task-timer-control task-timer-control--detail{% if is_active_timer %} is-active{% endif %}" title="{{ is_active_timer ? 'Stop timer' : 'Start timer' }}" aria-label="{{ is_active_timer ? 'Stop task timer' : 'Start task timer' }}">
                            {% if is_active_timer %}
                                <svg viewBox="0 0 24 24" aria-hidden="true"><rect x="7" y="7" width="10" height="10" rx="1"></rect></svg>
                            {% else %}
                                <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 6.8v10.4L17 12 9 6.8Z"></path></svg>
                            {% endif %}
                        </button>
                    </form>
                {% endif %}
                <a class="button button-secondary" href="{{ path('admin_task_edit', {id: selected_task.id}) }}">Edit</a>
                <a class="task-dialog-close" data-task-dialog-close href="{{ path('admin_tasks', {project: selected_project.id}) }}" aria-label="Close">×</a>
            </div>
        </header>

        <div class="task-detail-summary">
            <form method="post" action="{{ path('admin_task_detail_status', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_status_' ~ selected_task.id) }}"><label>Status<select name="status" onchange="this.form.submit()">{% for value, label in {'todo':'To do','in_progress':'In progress','paused':'Paused','completed':'Completed'} %}<option value="{{ value }}"{% if selected_task.status == value %} selected{% endif %}>{{ label }}</option>{% endfor %}</select></label></form>
            <dl class="task-summary-grid"><div><dt>Priority</dt><dd>{{ selected_task.priority|status_label }}</dd></div><div><dt>Completion</dt><dd>{{ selected_task.completionPercentage }}%</dd></div><div><dt>Assignees</dt><dd>{% for user in selected_task.assignees %}{{ user.fullName }}{% if not loop.last %}, {% endif %}{% else %}Unassigned{% endfor %}</dd></div><div><dt>Tags</dt><dd>{{ selected_task.tags ? selected_task.tags|join(', ') : 'None' }}</dd></div><div><dt>Schedule</dt><dd>{{ selected_task.startDate ? selected_task.startDate|date('d.m.Y') : 'No start' }} – {{ selected_task.dueDate ? selected_task.dueDate|date('d.m.Y') : 'No due date' }}</dd></div><div><dt>Time</dt><dd><span{% if is_active_timer %} data-live-duration data-base-seconds="{{ selected_task.trackedSeconds }}" data-start-timestamp="{{ active_task_entry.startedAt|date('U') }}"{% endif %}>{{ selected_task.trackedSeconds|duration }}</span> tracked / {{ selected_task.estimatedMinutes ?: 0 }} min estimated</dd></div><div><dt>Reminder</dt><dd>{{ selected_task.reminderAt ? selected_task.reminderAt|date('d.m.Y H:i') : 'None' }}</dd></div><div><dt>Recurrence</dt><dd>{{ selected_task.recurrence ? selected_task.recurrence|status_label : 'None' }}</dd></div><div><dt>Billing</dt><dd>{{ selected_task.billingType|status_label }}</dd></div></dl>
            {% if selected_task.description %}<div class="task-description">{{ selected_task.description|nl2br }}</div>{% endif %}
            {% if selected_task.managerNote %}<div class="manager-note"><strong>Manager note</strong><p>{{ selected_task.managerNote|nl2br }}</p></div>{% endif %}
        </div>

        <nav class="task-panel-tabs" data-task-tabs>{% for id, label in {'comments':'Comments','subtasks':'Subtasks','time':'Time Logs','documents':'Documents','dependencies':'Dependencies','history':'Status Timeline','problems':'Problems','activity':'Activity'} %}<button type="button" data-task-tab="{{ id }}"{% if loop.first %} class="active" aria-selected="true"{% else %} aria-selected="false"{% endif %}>{{ label }}{% if id == 'subtasks' %} ({{ selected_task.children|length }}){% endif %}</button>{% endfor %}</nav>

        <div class="task-panel-body">
            <section data-task-panel="comments"><form class="post-comment-form" method="post" action="{{ path('admin_task_comment', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('comment_' ~ selected_task.id) }}"><label>Write a comment<textarea name="body" rows="3" required></textarea></label><button>Post Comment</button></form>{% for comment in selected_task.comments %}<article class="comment-item"><strong>{{ comment.author ? comment.author.fullName : 'Deleted user' }}</strong><small>{{ comment.createdAt|date('d.m.Y H:i') }}</small><p>{{ comment.body|nl2br }}</p></article>{% else %}<p class="muted">No comments yet.</p>{% endfor %}</section>
            <section data-task-panel="subtasks" hidden><a class="button" href="{{ path('admin_task_new', {project: selected_project.id, parent: selected_task.id}) }}">Add Subtask</a><div class="stack">{% for child in selected_task.children %}<a class="card task-subtask-link" href="{{ path('admin_tasks', {project: selected_project.id, task: child.id}) }}"><strong>{{ child.title }}</strong><span class="badge">{{ child.status|status_label }}</span></a>{% else %}<p class="muted">No subtasks yet.</p>{% endfor %}</div></section>
            <section data-task-panel="time" hidden><form class="inline-form" method="post" action="{{ path('admin_task_detail_time_log', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_time_' ~ selected_task.id) }}"><label>Employee<select name="employee_id" required>{% for employee in selected_project.employees %}<option value="{{ employee.id }}">{{ employee.fullName }}</option>{% endfor %}</select></label><label>Minutes<input type="number" name="minutes" min="1" max="1440" required></label><label>Note<input name="note"></label><button>Add Time Log</button></form>{% for entry in selected_task.timeEntries %}<div class="detail-row"><strong>{{ entry.employee.fullName }}</strong><span>{{ entry.seconds|duration }} · {{ entry.startedAt|date('d.m.Y H:i') }}</span></div>{% else %}<p class="muted">No time logged.</p>{% endfor %}</section>
            <section data-task-panel="documents" hidden><form class="inline-form" method="post" enctype="multipart/form-data" action="{{ path('admin_task_detail_document_upload', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_document_' ~ selected_task.id) }}"><input type="file" name="document" required><button>Upload</button></form>{% for document in selected_task.documents %}<div class="detail-row"><a href="{{ path('admin_task_detail_document_download', {id: document.id}) }}">{{ document.originalFilename }}</a><form method="post" action="{{ path('admin_task_detail_document_delete', {id: document.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_document_delete_' ~ document.id) }}"><button class="danger">Delete</button></form></div>{% else %}<p class="muted">No documents attached.</p>{% endfor %}</section>
            <section data-task-panel="dependencies" hidden><form class="inline-form" method="post" action="{{ path('admin_task_detail_dependency_add', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_dependency_' ~ selected_task.id) }}"><select name="prerequisite_id" required><option value="">Choose prerequisite</option>{% for candidate in selected_project.tasks %}{% if candidate.id != selected_task.id %}<option value="{{ candidate.id }}">#{{ candidate.id }} {{ candidate.title }}</option>{% endif %}{% endfor %}</select><button>Add Dependency</button></form>{% for dependency in selected_task.dependencies %}<div class="detail-row"><span>#{{ dependency.prerequisite.id }} {{ dependency.prerequisite.title }} · {{ dependency.prerequisite.status|status_label }}</span><form method="post" action="{{ path('admin_task_detail_dependency_delete', {id: dependency.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_dependency_delete_' ~ dependency.id) }}"><button class="danger">Remove</button></form></div>{% else %}<p class="muted">No dependencies.</p>{% endfor %}</section>
            <section data-task-panel="history" hidden>{% for history in selected_task.statusHistory %}<div class="detail-row"><span>{{ history.previousStatus|status_label }} → {{ history.newStatus|status_label }}</span><small>{{ history.actor ? history.actor.fullName : 'System' }} · {{ history.createdAt|date('d.m.Y H:i') }}</small></div>{% else %}<p class="muted">No status changes recorded.</p>{% endfor %}</section>
            <section data-task-panel="problems" hidden><form class="post-comment-form" method="post" action="{{ path('admin_task_detail_problem_add', {id: selected_task.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_problem_' ~ selected_task.id) }}"><textarea name="description" rows="2" required placeholder="Describe a blocker or problem"></textarea><button>Report Problem</button></form>{% for problem in selected_task.problems %}<div class="problem-item{% if problem.resolved %} is-resolved{% endif %}"><p>{{ problem.description }}</p><small>{{ problem.author ? problem.author.fullName : 'Deleted user' }} · {{ problem.createdAt|date('d.m.Y H:i') }}</small>{% if not problem.resolved %}<form method="post" action="{{ path('admin_task_detail_problem_resolve', {id: problem.id}) }}"><input type="hidden" name="_token" value="{{ csrf_token('task_problem_resolve_' ~ problem.id) }}"><button class="success">Resolve</button></form>{% else %}<span class="badge badge-success">Resolved</span>{% endif %}</div>{% else %}<p class="muted">No problems reported.</p>{% endfor %}</section>
            <section data-task-panel="activity" hidden>{% for item in selected_task.activities %}<div class="detail-row"><span>{{ item.summary }}</span><small>{{ item.actor ? item.actor.fullName : 'System' }} · {{ item.createdAt|date('d.m.Y H:i') }}</small></div>{% else %}<p class="muted">No activity recorded.</p>{% endfor %}</section>
        </div>
    </div>
</section>
