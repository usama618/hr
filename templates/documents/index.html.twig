{% extends 'base.html.twig' %}

{% block title %}Documents | Waldbyte HR{% endblock %}

{% block body %}
    <div class="page-title">
        <div>
            <span class="panel-label">Files</span>
            <h1>Document Center</h1>
            <p class="muted">Store policies, contracts, payslips, certificates, and private employee files.</p>
        </div>
    </div>

    <section class="grid grid-3 document-metrics">
        <article class="card">
            <span class="panel-label">Visible</span>
            <h2>Documents</h2>
            <div class="metric">{{ documents|length }}</div>
        </article>
        <article class="card">
            <span class="panel-label">Storage</span>
            <h2>Total Size</h2>
            <div class="metric">{{ (total_size / 1024 / 1024)|number_format(1) }} MB</div>
        </article>
        <article class="card">
            <span class="panel-label">Access</span>
            <h2>Scope</h2>
            {% if can_upload_company_documents %}
                <p class="muted">Choose all employees for company documents, or one employee for private files.</p>
            {% else %}
                <p class="muted">Documents you upload are private to your account. Company documents are added by admins.</p>
            {% endif %}
        </article>
    </section>

    <section class="document-layout">
        <article class="card document-upload-card">
            <h2>Upload Document</h2>
            <form class="document-upload-form" method="post" action="{{ path('app_documents_upload') }}" enctype="multipart/form-data">
                <input type="hidden" name="_token" value="{{ csrf_token('document_upload') }}">
                <label>
                    <span>Title</span>
                    <input type="text" name="title" placeholder="Document title">
                </label>
                <label>
                    <span>Category</span>
                    <select name="category">
                        {% for value, label in document_categories %}
                            <option value="{{ value }}">{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>
                {% if can_upload_company_documents %}
                    <label>
                        <span>Visible To</span>
                        <select name="owner_id">
                            <option value="0">All employees</option>
                            {% for employee in document_employees %}
                                <option value="{{ employee.id }}">{{ employee.fullName }}{% if employee.jobTitle %} - {{ employee.jobTitle }}{% endif %}</option>
                            {% endfor %}
                        </select>
                    </label>
                {% else %}
                    <p class="muted document-upload-note">Your upload will be saved as a private personal document.</p>
                {% endif %}
                <label>
                    <span>Description</span>
                    <textarea name="description" rows="3" placeholder="Optional notes"></textarea>
                </label>
                <label>
                    <span>File</span>
                    <input type="file" name="document_file" accept=".pdf,.doc,.docx,.xls,.xlsx,.jpg,.jpeg,.png,.webp,.txt" required>
                </label>
                <button type="submit">Upload</button>
            </form>
        </article>

        <section class="document-list-panel">
            <form class="document-filter card" method="get" action="{{ path('app_documents_index') }}">
                <label>
                    <span>Search</span>
                    <input type="search" name="q" value="{{ document_query }}" placeholder="Title, filename, notes">
                </label>
                <label>
                    <span>Category</span>
                    <select name="category">
                        <option value="">All categories</option>
                        {% for value, label in document_categories %}
                            <option value="{{ value }}" {% if document_category == value %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </label>
                <button type="submit">Filter</button>
            </form>

            <div class="document-list">
                {% for document in documents %}
                    <article class="card document-item">
                        <div class="document-icon" aria-hidden="true">{{ document.category|slice(0, 1)|upper }}</div>
                        <div class="document-copy">
                            <h3>{{ document.title }}</h3>
                            <p class="muted">
                                {{ document.originalFilename }}
                                &middot;
                                {{ (document.fileSize / 1024)|number_format(0) }} KB
                                &middot;
                                {{ document.createdAt|date('Y-m-d') }}
                            </p>
                            {% if document.description %}
                                <p>{{ document.description }}</p>
                            {% endif %}
                            <div class="document-meta-row">
                                <span class="badge">{{ document_categories[document.category]|default(document.category|status_label) }}</span>
                                {% if document.companyWide %}
                                    <span class="badge badge-success">Company</span>
                                {% else %}
                                    <span class="badge">{{ document.owner.fullName }}</span>
                                {% endif %}
                                {% if document.uploadedBy %}
                                    <span class="muted">Uploaded by {{ document.uploadedBy.fullName }}</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="document-actions">
                            <a class="button button-secondary" href="{{ path('app_documents_download', {id: document.id}) }}">Download</a>
                            {% if is_granted('ROLE_SUPER_ADMIN') or (document.owner and app.user and document.owner.id == app.user.id) %}
                                <form method="post" action="{{ path('app_documents_delete', {id: document.id}) }}" onsubmit="return confirm('Delete {{ document.title|e('js') }}?');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('document_delete_' ~ document.id) }}">
                                    <button type="submit" class="danger">Delete</button>
                                </form>
                            {% endif %}
                        </div>
                    </article>
                {% else %}
                    <article class="card">
                        <p class="muted">No documents found.</p>
                    </article>
                {% endfor %}
            </div>
        </section>
    </section>
{% endblock %}
